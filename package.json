  "bugs": {
    "url": "https://github.com/fupslot/web-desk/issues"
  },
  "devDependencies": {
    "bower": "^1.8.14",
    "grunt": "~0.4.2",
    "grunt-cli": "^1.5.0",
    "grunt-contrib-requirejs": "~0.4.1",
    "grunt-contrib-copy": "~0.5.0",
    "grunt-contrib-uglify": "~0.2.7"
  }
}
